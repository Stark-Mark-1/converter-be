# Cloudflare R2 credentials
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key

# Public base URL for the R2 bucket (custom domain or r2.dev URL)
R2_PUBLIC_BASE=https://pub-<token>.r2.dev

# Server config (optional)
PORT=3000
# Restrict CORS to your frontend origin in production (default: *)
CORS_ORIGIN=https://your-frontend-domain.com
